{
  "manifest_version": 3,
  "name": "403 Whisperer — Docs to Markdown for AI",
  "version": "1.0.0",
  "description": "Turn any docs page into clean, RAG-ready Markdown for AI. Beat 403/Cloudflare blocks, stale versions & missing context. 100% local.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "action": {
    "default_title": "403 Whisperer — ingest this docs page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
